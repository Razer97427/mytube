# ─────────────────────────────────────────────────────────────────────────────
# MyTube — configuration
# Copier ce fichier en .env et remplir les valeurs souhaitées.
# Les valeurs par défaut fonctionnent SANS VPN.
# ─────────────────────────────────────────────────────────────────────────────

# Clé secrète des sessions (changer en production)
SESSION_SECRET=changeme_in_production

# ─────────────────────────────────────────────────────────────────────────────
# VPN — laisser vide pour démarrer SANS VPN
# ─────────────────────────────────────────────────────────────────────────────

# ── Option 1 : NordVPN (ou autre fournisseur gluetun) ────────────────────────
# Identifiants : Dashboard NordVPN → Manual Setup → OpenVPN credentials
#VPN_PROVIDER=nordvpn
#VPN_USER=your_nordvpn_service_username
#VPN_PASS=your_nordvpn_service_password
#VPN_COUNTRY=France

# ── Option 2 : fichier .ovpn custom ─────────────────────────────────────────
# Placer le fichier dans ./vpn/client.ovpn (ou autre chemin)
#VPN_PROVIDER=custom
#OVPN_FILE=./vpn/client.ovpn
#VPN_USER=   # optionnel, si le fichier .ovpn demande un identifiant
#VPN_PASS=   # optionnel

# ── Activer le proxy VPN (décommenter si VPN activé) ─────────────────────────
# DOIT correspondre à l'une des deux options ci-dessus
#PROXY_URL=http://vpn:8888
