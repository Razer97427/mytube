# ═══════════════════════════════════════════════════════════════════════════
# MyTube — fichier de configuration
#
# ► Copier en .env et remplir les valeurs souhaitées
# ► Portainer : coller les variables directement dans
#   Stacks → [stack] → Editor → "Environment variables"
#   (inutile de créer un fichier .env sur le serveur dans ce cas)
# ═══════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# SÉCURITÉ
# ─────────────────────────────────────────────────────────────────────────────
# Changer obligatoirement en production (chaine aléatoire longue)
SESSION_SECRET=changeme_in_production


# ─────────────────────────────────────────────────────────────────────────────
# PORTS EXPOSÉS  (modifier si conflits sur le serveur hôte)
# ─────────────────────────────────────────────────────────────────────────────
#FRONTEND_PORT=3000
#BACKEND_PORT=8080
#POT_PORT=4416


# ─────────────────────────────────────────────────────────────────────────────
# VOLUMES / CHEMINS DE DONNÉES
# Laisser vide = Docker gère les volumes automatiquement (recommandé par défaut)
# Renseigner un chemin absolu = bind mount vers ce dossier (NFS, CIFS, local…)
#
# Le dossier doit exister sur l'hôte avant le démarrage.
# Exemple partage NFS monté sur /mnt/monpartage :
#   CACHE_PATH=/mnt/monpartage/mytube/yt-cache
#   POT_DATA_PATH=/mnt/monpartage/mytube/pot-data
# ─────────────────────────────────────────────────────────────────────────────
#CACHE_PATH=
#POT_DATA_PATH=


# ─────────────────────────────────────────────────────────────────────────────
# VPN (optionnel) — laisser tout commenté pour démarrer sans VPN
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A : fournisseur prédéfini (NordVPN, ExpressVPN, Surfshark…) ───────
# Identifiants OpenVPN : Dashboard NordVPN → Manual Setup → OpenVPN credentials
# (différents de votre identifiant de compte NordVPN)
#VPN_PROVIDER=nordvpn
#VPN_USER=your_service_username
#VPN_PASS=your_service_password
#VPN_COUNTRY=France

# ── Option B : fichier .ovpn personnalisé ─────────────────────────────────────
# Chemin absolu vers le fichier .ovpn sur l'hôte
#VPN_PROVIDER=custom
#OVPN_FILE=/mnt/monpartage/vpn/client.ovpn
#VPN_USER=    # optionnel
#VPN_PASS=    # optionnel

# ── Activer le proxy VPN (obligatoire si VPN activé) ─────────────────────────
#PROXY_URL=http://vpn:8888


# ─────────────────────────────────────────────────────────────────────────────
# CONNEXION GOOGLE (optionnel)
# Débloque : fil personnalisé, abonnements, synchronisation historique
#
# Créer les credentials sur console.cloud.google.com :
#   1. Nouveau projet (nom quelconque)
#   2. APIs & Services → Activer "YouTube Data API v3"
#   3. Écran consentement OAuth → Externe → scope : youtube.readonly
#   4. Identifiants → Créer → OAuth client ID → "TV et appareils à saisie limitée"
# ─────────────────────────────────────────────────────────────────────────────
#YOUTUBE_CLIENT_ID=votre_client_id.apps.googleusercontent.com
#YOUTUBE_CLIENT_SECRET=votre_secret


# ─────────────────────────────────────────────────────────────────────────────
# SERVICES EXTERNES (modifier uniquement si vous utilisez des mirrors)
# ─────────────────────────────────────────────────────────────────────────────
#SPONSORBLOCK_API=https://sponsor.ajay.app
#POT_PROVIDER_URL=http://pot-provider:4416
